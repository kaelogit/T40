# Supabase (storefront + admin)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site URL — required for OG tags, payment return URLs, emails
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin subdomain (production)
# ADMIN_HOSTS=admin.t40perfumesng.com
# ALLOW_ADMIN_ON_MAIN_HOST=true

# Cloudflare R2 — admin image uploads (products, blog, CMS)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
# Optional overrides:
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_PUBLIC_HOSTNAME=assets.t40perfumesng.com

# Paystack (NGN) — live keys for production
# PAYSTACK_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_...
# Webhook URL (Paystack Dashboard): https://t40perfumesng.com/api/webhooks/paystack

# Stripe (international) — set both to true when Stripe is registered
# STRIPE_CHECKOUT_ENABLED=false
# NEXT_PUBLIC_STRIPE_CHECKOUT_ENABLED=false
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Webhook URL (Stripe Dashboard): https://t40perfumesng.com/api/webhooks/stripe
# Event: checkout.session.completed

# Email (Resend)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=T40 Perfumes <orders@yourdomain.com>

# Social links — leave blank until ready; remove unused platforms from SOCIAL_PLATFORM_ORDER in lib/site/social.ts
# NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/t40perfumes
# NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/t40perfumes
# NEXT_PUBLIC_TIKTOK_URL=https://tiktok.com/@t40perfumes
# NEXT_PUBLIC_X_URL=https://x.com/t40perfumes
# NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@t40perfumes
# NEXT_PUBLIC_PINTEREST_URL=https://pinterest.com/t40perfumes
# NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/234XXXXXXXXXX
